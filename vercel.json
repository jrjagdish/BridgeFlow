{
  "version": 2,
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "src": "/oauth/(.*)",   "dest": "/main.py" },
    { "src": "/notion/(.*)",  "dest": "/main.py" },
    { "src": "/sheets/(.*)",  "dest": "/main.py" },
    { "src": "/config",        "dest": "/main.py" },
    { "src": "/me",            "dest": "/main.py" },
    { "src": "/status",        "dest": "/main.py" },
    { "src": "/logout",        "dest": "/main.py" },
    { "src": "/sync/(.*)",     "dest": "/main.py" },
    { "src": "/cron/(.*)",    "dest": "/main.py" },
    { "src": "/docs(.*)",     "dest": "/main.py" },
    { "src": "/openapi.json", "dest": "/main.py" },
    
    { "src": "/assets/(.*)",   "dest": "/assets/$1" },
    
    { "handle": "filesystem" },
    
    { "src": "/(.*)",          "dest": "/index.html" }
  ]
}
